":"Ahri se cura tras matar 9 súbditos o monstruos.<br>Ahri se cura un mayor porcentaje tras derrotar a un campeón enemigo.","image":{"full":"Ahri_SoulEater2.png","sprite":"passive0.png","group":"passive","x":48,"y":0,"w":48,"h":48}},"recommended":[]}